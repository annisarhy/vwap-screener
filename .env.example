# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=token_dari_botfather
TELEGRAM_CHAT_ID=chat_id_kamu

# ── Screener ───────────────────────────────────────────────
SCREENER_INTERVAL=15        # menit antar auto-run (default 15 = setiap candle)
SCREENER_TIMEFRAME=15m      # timeframe utama
SCREENER_TOP_N=50           # jumlah coin top volume yang di-scan
SCREENER_MIN_CONVICTION=1   # 1=Low+ | 2=Medium+ | 3=High only
SCREENER_TOP_DISPLAY=5      # max tampil di summary

# ── Optional ───────────────────────────────────────────────
SIGNAL_LOG_PATH=/app/data/signals_log.json
