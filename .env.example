# ── Telegram ───────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=token_dari_botfather
TELEGRAM_CHAT_ID=chat_id_kamu

# ── Screener ───────────────────────────────────────────────
SCREENER_INTERVAL_5M=300     # interval 5m dalam detik (default 300)
SCREENER_INTERVAL_15M=900    # interval 15m dalam detik (default 900)
SCREENER_TOP_N=50            # jumlah coin yang di-scan
SCREENER_MIN_CONVICTION=1    # 1=Low+ | 2=Medium+ | 3=High only
SCREENER_TOP_DISPLAY=5       # max tampil di summary Telegram

# ── Google Sheets ───────────────────────────────────────────
# Ambil ID dari URL: https://docs.google.com/spreadsheets/d/<ID>/edit
GOOGLE_SHEET_ID=spreadsheet_id_kamu

# Cara 1 — paste isi JSON service account (satu baris)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Cara 2 — path file JSON (lebih mudah kalau local/Docker)
# GOOGLE_SERVICE_ACCOUNT_FILE=/app/sa.json

GOOGLE_SHEET_TAB=Signals     # nama tab (default: Signals)
PRICE_REFRESH_SEC=60         # update harga tiap N detik
